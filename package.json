{
	"private": true,
	"type": "module",
	"scripts": {
		"build": "qwik build",
		"build.client": "vite build",
		"build.preview": "vite build --ssr src/entry.preview.tsx",
		"build.server": "qwik check-client src dist && vite build -c adapters/vercel-edge/vite.config.ts",
		"build.types": "tsc --incremental --noEmit",
		"deploy": "vercel deploy",
		"dev": "vite --mode ssr",
		"dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
		"fmt": "oxfmt",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"preview": "qwik build preview && vite preview --open",
		"start": "vite --open --mode ssr",
		"qwik": "qwik"
	},
	"devDependencies": {
		"@builder.io/qwik": "catalog:dev",
		"@builder.io/qwik-city": "catalog:dev",
		"@iconify-json/carbon": "catalog:dev",
		"@types/node": "catalog:types",
		"oxfmt": "catalog:lint",
		"oxlint": "catalog:lint",
		"oxlint-plugin-qwik": "catalog:lint",
		"oxlint-tsgolint": "catalog:lint",
		"typescript": "catalog:types",
		"typescript-plugin-css-modules": "catalog:types",
		"unocss": "^66.6.8",
		"vercel": "^29.1.1",
		"vite": "catalog:build",
		"vite-tsconfig-paths": "catalog:build"
	},
	"engines": {
		"node": ">=21"
	},
	"packageManager": "pnpm@10.33.0",
	"engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime"
}
